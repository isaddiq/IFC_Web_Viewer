{
  "name": "bimxr-viewer",
  "version": "0.0.117",
  "private": true,
  "type": "module",
  "author": "IFC.js",
  "license": "MIT",
  "description": "BIMXR IFC viewer application.",
  "keywords": [
    "bim",
    "openbim",
    "ifc",
    "architecture",
    "engineering",
    "construction",
    "aec"
  ],
  "scripts": {
    "build": "rollup -c && npm run copy-runtime",
    "watch": "rollup -c -w",
    "copy-runtime": "cpy ../node_modules/web-ifc/web-ifc.wasm assets/js && cpy ../node_modules/web-ifc/web-ifc-mt.wasm assets/js && cpy ../web-ifc-three/dist/IFCWorker.js assets/js && cpy ../web-ifc-three/dist/IFCWorker.js.map assets/js"
  },
  "dependencies": {
    "aframe-click-drag-component": "^3.0.1",
    "stats.js": "^0.17.0",
    "three": "^0.135.0",
    "web-ifc": "^0.0.35",
    "web-ifc-three": "^0.0.117"
  },
  "devDependencies": {
    "cpy-cli": "^3.1.1"
  }
}
